<?xml version="1.0" encoding="UTF-8"?>
<!--
  Shared structured-logging config. Any service with common-observability on its classpath and no
  logback config of its own picks this up automatically. Emits one JSON object per line (stdout) with
  the MDC fields (incl. correlationId) so logs are queryable by a collector.

  Override per env with a service-local logback-spring.xml if ever needed.
-->
<configuration>
    <springProperty scope="context" name="appName" source="spring.application.name" defaultValue="heimcall"/>

    <appender name="JSON" class="ch.qos.logback.core.ConsoleAppender">
        <encoder class="net.logstash.logback.encoder.LogstashEncoder">
            <includeMdcKeyName>correlationId</includeMdcKeyName>
            <!-- Phase 8 T4: Micrometer Tracing's correlation listener stamps these into the MDC. -->
            <includeMdcKeyName>traceId</includeMdcKeyName>
            <includeMdcKeyName>spanId</includeMdcKeyName>
            <customFields>{"service":"${appName}"}</customFields>
            <fieldNames>
                <timestamp>ts</timestamp>
                <message>msg</message>
                <logger>logger</logger>
                <thread>thread</thread>
                <levelValue>[ignore]</levelValue>
            </fieldNames>
        </encoder>
    </appender>

    <root level="INFO">
        <appender-ref ref="JSON"/>
    </root>
</configuration>
