{
  "annotations": { "list": [] },
  "editable": true,
  "schemaVersion": 39,
  "title": "Heimcall — Redis",
  "tags": ["heimcall", "redis"],
  "time": { "from": "now-1h", "to": "now" },
  "refresh": "15s",
  "templating": { "list": [] },
  "panels": [
    {
      "id": 1,
      "title": "Exporter up",
      "type": "stat",
      "gridPos": { "h": 5, "w": 6, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "mappings": [ { "type": "value", "options": { "0": { "text": "DOWN", "color": "red" }, "1": { "text": "UP", "color": "green" } } } ] }, "overrides": [] },
      "targets": [ { "expr": "redis_up", "legendFormat": "redis_up" } ]
    },
    {
      "id": 2,
      "title": "Connected clients",
      "type": "stat",
      "gridPos": { "h": 5, "w": 6, "x": 6, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [ { "expr": "redis_connected_clients", "legendFormat": "clients" } ]
    },
    {
      "id": 3,
      "title": "Keys (total)",
      "type": "stat",
      "gridPos": { "h": 5, "w": 6, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [ { "expr": "sum(redis_db_keys)", "legendFormat": "keys" } ]
    },
    {
      "id": 4,
      "title": "Memory used (bytes)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 5 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "bytes" }, "overrides": [] },
      "targets": [ { "expr": "redis_memory_used_bytes", "legendFormat": "used" } ]
    },
    {
      "id": 5,
      "title": "Commands processed (per s)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 5 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [ { "expr": "rate(redis_commands_processed_total[5m])", "legendFormat": "ops/s" } ]
    },
    {
      "id": 6,
      "title": "Keyspace hit ratio",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 13 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "percentunit", "min": 0, "max": 1 }, "overrides": [] },
      "targets": [ { "expr": "rate(redis_keyspace_hits_total[5m]) / (rate(redis_keyspace_hits_total[5m]) + rate(redis_keyspace_misses_total[5m]))", "legendFormat": "hit ratio" } ]
    },
    {
      "id": 7,
      "title": "Evicted / expired keys (per s)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 13 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "rate(redis_evicted_keys_total[5m])", "legendFormat": "evicted" },
        { "expr": "rate(redis_expired_keys_total[5m])", "legendFormat": "expired" }
      ]
    }
  ],
  "__inputs": [],
  "__requires": []
}
